DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/swts_db
SECRET_KEY=your-secret-key-here

# Keycloak (backend — for token verification)
KEYCLOAK_URL=http://localhost:8080
KEYCLOAK_REALM=swts-realm
KEYCLOAK_CLIENT_ID=swts-app

# Keycloak (frontend — must be prefixed NEXT_PUBLIC_)
NEXT_PUBLIC_KEYCLOAK_URL=http://localhost:8080
NEXT_PUBLIC_KEYCLOAK_REALM=swts-realm
NEXT_PUBLIC_KEYCLOAK_CLIENT_ID=swts-app
